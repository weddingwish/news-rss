# このファイルをコピーして .env を作り、実際のキーを入れる。
# .env は .gitignore 済みなので Git にもGitHubにも上がりません（漏洩しません）。
# クラウド(GitHub Actions)では .env は使わず、GitHub Secrets に登録します。

# Slack Incoming Webhook（毎朝の投稿先）
SLACK_WEBHOOK_URL=

# DeepSeek APIキー（AIエンリッチを使う場合のみ。未設定ならキーワードモードで動作）
DEEPSEEK_API_KEY=

# 使用モデル/エンドポイント（任意・既定は deepseek-chat）
# AI_MODEL=deepseek-chat
# AI_BASE_URL=https://api.deepseek.com
